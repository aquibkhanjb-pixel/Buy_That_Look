# ================================================================
# Fashion Recommendation System - Docker Environment Configuration
# ================================================================
# Copy this file to .env and update values for your environment:
#   cp .env.example .env
# ================================================================

# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=fashionuser
POSTGRES_PASSWORD=fashionpass
POSTGRES_DB=fashiondb
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────
REDIS_PORT=6379

# ─── Backend API ──────────────────────────────────────────────────
BACKEND_PORT=8000
DEBUG=false
CLIP_MODEL_NAME=ViT-B/32

# ─── Frontend ─────────────────────────────────────────────────────
FRONTEND_PORT=3000
