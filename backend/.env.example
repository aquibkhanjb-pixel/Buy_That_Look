# Fashion Recommendation System - Environment Configuration
# Copy this file to .env and update values for your environment

# Application
APP_NAME=Fashion Recommendation API
APP_VERSION=0.1.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/fashiondb

# Redis Cache
REDIS_URL=redis://localhost:6379

# ML Model Configuration
CLIP_MODEL_NAME=ViT-B/32
MODEL_CACHE_DIR=./models

# FAISS Index
FAISS_INDEX_PATH=./data/indices/fashion_products.index

# Storage
IMAGE_STORAGE_PATH=./data/images
MAX_UPLOAD_SIZE=10485760

# API Settings
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# Rate Limiting
RATE_LIMIT_PER_MINUTE=30

# Search Defaults
DEFAULT_SEARCH_K=20
MAX_SEARCH_K=100
